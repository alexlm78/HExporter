# Copiar a `.env` y completar. NUNCA commitear `.env` con credenciales reales.
# Convención: HEXPORTER_<Seccion>__<Clave> (doble guion bajo = separador jerárquico de config).
# Ver docs/05-configuration.md §2 y docs/06-nfr-ops.md §Seguridad.

# Cadena de conexión Oracle. Preferir Oracle Wallet en producción (sin password en texto).
HEXPORTER_Oracle__ConnectionString=User Id=rpt;Password=CAMBIAR;Data Source=host:1521/servicio

# Bytes por lote de red del driver (~256KB-1MB). No es el resultado completo — ver docs/04-streaming-strategy.md.
HEXPORTER_Oracle__FetchSizeBytes=1048576

# 0 = sin límite (reportes largos).
HEXPORTER_Oracle__CommandTimeoutSeconds=0

HEXPORTER_Oracle__BindByName=true
